{
  "name": "jianzhong",
  "version": "1.0.0",
  "description": "简钟 - 简约精致的桌面事件提醒应用",
  "author": {
    "name": "fengshao",
    "email": "2231241522@qq.com"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "electron:dev:build": "vite build && electron .",
    "electron:build": "vite build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "chinese-workday": "^2.0.0",
    "electron-store": "^8.1.0",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint-plugin-vue": "^9.25.0",
    "typescript": "^6.0.2",
    "vite": "^5.1.4",
    "vitest": "^3.0.0",
    "vue-tsc": "^3.2.6",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.kylin.alarm",
    "productName": "简钟",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "public/icon.png"
    },
    "win": {
      "target": "nsis"
    }
  }
}
